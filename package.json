    "smoke:platforms-save": "npm run diagnostic:e2e:platforms-save --",
    "diagnostic:e2e:platform-operations": "node scripts/platform-operations-e2e-smoke.mjs",
    "smoke:platform-operations-e2e": "npm run diagnostic:e2e:platform-operations --",
    "diagnostic:e2e:platform-ops-with-health": "node scripts/platform-ops-with-health-smoke.mjs",
    "smoke:platform-ops-with-health": "npm run diagnostic:e2e:platform-ops-with-health --",
