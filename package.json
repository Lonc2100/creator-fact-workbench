    "smoke:douyin-save": "npm run diagnostic:e2e:douyin-save --",
    "diagnostic:e2e:xiaohongshu-save": "tsx scripts/xiaohongshu-personal-save-smoke.mjs",
    "smoke:xiaohongshu-save": "npm run diagnostic:e2e:xiaohongshu-save --",
    "diagnostic:e2e:video-account-save": "tsx scripts/video-account-personal-save-smoke.mjs",
    "smoke:video-account-save": "npm run diagnostic:e2e:video-account-save --",
    "diagnostic:e2e:bilibili-save": "tsx scripts/bilibili-personal-save-smoke.mjs",
    "smoke:bilibili-save": "npm run diagnostic:e2e:bilibili-save --",
