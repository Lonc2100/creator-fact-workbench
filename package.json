    "check:real-capture-freshness": "npm run diagnostic:real-capture-freshness --",
    "diagnostic:local-data-quarantine": "node scripts/local-data-quarantine-report.mjs",
    "check:local-data-quarantine": "npm run diagnostic:local-data-quarantine --",
    "scan:entropy": "node scripts/entropy-governance-scan.mjs",
    "diagnostic:local-server-health": "node scripts/local-server-health.mjs",
    "check:local-server-health": "npm run diagnostic:local-server-health --",
    "diagnostic:trusted-dashboard-audit": "node scripts/trusted-dashboard-audit.mjs",
    "audit:trusted-dashboard": "npm run diagnostic:trusted-dashboard-audit --",
    "diagnostic:clean-profile": "tsx scripts/clean-profile-status.mjs",
